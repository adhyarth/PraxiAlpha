# ==========================================
# PraxiAlpha Environment Variables
# ==========================================
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ---- Data Providers ----
EODHD_API_KEY=your_eodhd_api_key_here
FRED_API_KEY=your_fred_api_key_here
TE_API_KEY=guest:guest  # TradingEconomics (free tier; upgrade for full API access)

# ---- TradingView (data validation) ----
# Premium credentials for scripts/validate_tradingview.py
# pip install "praxialpha[tv-validate]" to install the tvdatafeed library
TV_USERNAME=your_tradingview_username_here
TV_PASSWORD=your_tradingview_password_here

# ---- Database ----
POSTGRES_USER=praxialpha
POSTGRES_PASSWORD=praxialpha_dev_2025
POSTGRES_DB=praxialpha
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ---- Celery ----
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/1

# ---- FastAPI ----
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-in-production

# ---- Logging ----
LOG_LEVEL=INFO

# ---- User Isolation (Trading Journal) ----
# Each user sets a unique ID so their trades are private.
# Defaults to "default" for single-user setups.
PRAXIALPHA_USER_ID=default

# ---- Future (Phase 5+) ----
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ALPACA_API_KEY=your_alpaca_api_key_here
# ALPACA_SECRET_KEY=your_alpaca_secret_key_here
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
